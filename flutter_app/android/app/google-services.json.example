{
  "_comment": "احصل على هذا الملف من Firebase Console وضعه هنا باسم google-services.json",
  "_instructions": [
    "1. اذهب إلى https://console.firebase.google.com/",
    "2. أنشئ مشروعاً جديداً باسم tamtom-store",
    "3. أضف تطبيق Android مع package name: com.tamtom.store",
    "4. حمّل ملف google-services.json وضعه في هذا المسار",
    "5. في main.dart استبدل YOUR_API_KEY وباقي القيم بقيم مشروعك"
  ],
  "project_info": {
    "project_number": "YOUR_PROJECT_NUMBER",
    "project_id": "YOUR_PROJECT_ID",
    "storage_bucket": "YOUR_PROJECT_ID.appspot.com"
  },
  "client": [
    {
      "client_info": {
        "mobilesdk_app_id": "YOUR_APP_ID",
        "android_client_info": {
          "package_name": "com.tamtom.store"
        }
      },
      "api_key": [
        {
          "current_key": "YOUR_API_KEY"
        }
      ],
      "services": {
        "appinvite_service": {
          "other_platform_oauth_client": []
        }
      }
    }
  ],
  "configuration_version": "1"
}
